{
  "name": "windkit",
  "version": "0.2.0",
  "description": "A protocol for connecting Vexanium DApps to the Wind wallet, enabling secure communication and transaction signing.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/windvex/windkit.git"
  },
  "keywords": [
    "cryptocurrency",
    "web3",
    "dapp",
    "walletconnect",
    "windkit",
    "web-rtc",
    "peerjs",
    "vexanium",
    "vex",
    "blockchain"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "echo \"(no tests yet)\""
  },
  "dependencies": {
    "@wharfkit/abicache": "^1.2.2",
    "@wharfkit/antelope": "^1.0.13",
    "@wharfkit/signing-request": "^3.2.0",
    "pako": "^2.1.0",
    "peerjs": "^1.5.4"
  },
  "devDependencies": {
    "@types/pako": "^2.0.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
